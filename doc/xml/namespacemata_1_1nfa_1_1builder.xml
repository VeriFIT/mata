        <definition>Nfa create_random_nfa_tabakov_vardi</definition>
        <argsstring>(const size_t num_of_states, const size_t alphabet_size, const double states_trans_ratio_per_symbol, const double final_state_density)</argsstring>
        <name>create_random_nfa_tabakov_vardi</name>
        <qualifiedname>mata::nfa::builder::create_random_nfa_tabakov_vardi</qualifiedname>
        <param>
          <type>const size_t</type>
          <declname>num_of_states</declname>
        </param>
        <param>
          <type>const size_t</type>
          <declname>alphabet_size</declname>
        </param>
